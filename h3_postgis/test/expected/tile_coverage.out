WITH linear_4326_buffered_focus_tiles AS (
    SELECT z,
           x,
           y,
           ST_MakeEnvelope(
               GREATEST(-180.0, -180.0 + (x - 0.125) * 360.0 / (1 << z)),
               GREATEST(-90.0, -90.0 + (y - 0.125) * 180.0 / (1 << z)),
               LEAST(180.0, -180.0 + (x + 1.125) * 360.0 / (1 << z)),
               LEAST(90.0, -90.0 + (y + 1.125) * 180.0 / (1 << z)),
