            (2),
            (dim.tiles / 4),
            (dim.tiles / 2),
            (dim.tiles - 3),
            (dim.tiles - 2),
            (dim.tiles - 1)
        ) AS xs(x)
        WHERE x BETWEEN 0 AND dim.tiles - 1
